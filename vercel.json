{
  "version": 2,
  "builds": [
    { "src": "api/server.js", "use": "@vercel/node" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "api/server.js" },
    { "source": "/css/(.*)", "destination": "public/css/$1" },
    { "source": "/js/(.*)", "destination": "public/js/$1" },
    { "source": "/assets/(.*)", "destination": "public/assets/$1" },
    { "source": "/recommendations", "destination": "public/recommendations.html" },
    { "source": "/spy", "destination": "public/spy.html" },
    { "source": "/subscribe", "destination": "public/subscribe.html" },
    
    
    { "source": "/account", "destination": "public/account.html" },
    { "source": "/blog", "destination": "/api/server.js" },
    { "source": "/blog/:slug", "destination": "/api/server.js" },
    { "source": "/admin", "destination": "public/admin.html" },
    { "source": "/(.*)", "destination": "public/$1" }
  ]
}
